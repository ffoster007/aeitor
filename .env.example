DATABASE_URL="postgresql://postgres:12671@localhost:5432/postgres"
NEXT_PUBLIC_SUPABASE_ANON_KEY="get_from_supabase"
SUPABASE_SERVICE_ROLE_KEY="get_from_supabase"
CRON_SECRET="generate_a_random_secret_here"
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxx"
# Optional: overrides sender shown in email notifications.
# If omitted, app falls back to "Aeitor <notify@aeitor.com>" from lib/email.ts.
RESEND_FROM_EMAIL="Aeitor <notify@yourdomain.com>"

## OAuth Configuration
GOOGLE_ID="google_id_here"
GOOGLE_SECRET="google_secret_here"
GITHUB_ID="github_client_id_here"
GITHUB_SECRET="github_client_secret_here"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

## Payment Configuration
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="your_stripe_publishable_key_here"
STRIPE_SECRET_KEY="your_stripe_secret_key_here"
STRIPE_WEBHOOK_SECRET="your_stripe_webhook_secret_here"
STRIPE_PRICE_GROWTH_MONTHLY="price_growth_monthly_here"
STRIPE_PRICE_SCALE_MONTHLY="price_scale_monthly_here"

## env.local additional variables
NEXTAUTH_SECRET=your_generated_secret_here
JWT_SECRET=your_generated_secret_here
