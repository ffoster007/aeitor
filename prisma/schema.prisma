// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(cuid())
  username      String         @unique
  email         String         @unique
  password      String          // bcrypt hash — ห้ามเก็บ plain text
  emailVerified Boolean        @default(false) @map("email_verified")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  refreshTokens RefreshToken[]
  oauthAccounts OAuthAccount[]
  vendors       Vendor[]
  alertSettings VendorAlertSetting[]
  verificationCodes VerificationCode[]
  subscription  Subscription?
  
  @@map("users")
}

enum BillingPlan {
  FREE
  GROWTH
  SCALE
}

enum BillingStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  INCOMPLETE
  INCOMPLETE_EXPIRED
  UNPAID
  PAUSED
}

model Subscription {
  id                   String        @id @default(cuid())
  userId               String        @unique @map("user_id")
  plan                 BillingPlan   @default(FREE)
  status               BillingStatus @default(CANCELED)
  stripeCustomerId     String?       @unique @map("stripe_customer_id")
  stripeSubscriptionId String?       @unique @map("stripe_subscription_id")
  currentPeriodStart   DateTime?     @map("current_period_start")
  currentPeriodEnd     DateTime?     @map("current_period_end")
  cancelAtPeriodEnd    Boolean       @default(false) @map("cancel_at_period_end")
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")
  user                 User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([plan])
  @@index([status])
  @@map("subscriptions")
}

model OAuthAccount {
  id                String   @id @default(cuid())
  provider          String
  providerAccountId String   @map("provider_account_id")
  userId            String   @map("user_id")
  createdAt         DateTime @default(now()) @map("created_at")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("oauth_accounts")
}

model VerificationCode {
  id        String   @id @default(cuid())
  code      String   // 6-digit OTP
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  attempts  Int      @default(0) // Track failed attempts
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("verification_codes")
}

model Vendor {
  id           String   @id @default(cuid())
  name         String
  endDate      DateTime @map("end_date")
  noticePeriod Int      @default(30) @map("notice_period") // days
  monthlyCost  Decimal  @map("monthly_cost") @db.Decimal(10, 2)
  userId       String   @map("user_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sentAlerts   VendorSentAlert[]

  @@index([userId])
  @@map("vendors")
}

// เก็บกี่วันล่วงหน้าที่ส่ง alert แล้ว (กัน duplicate send)
model VendorSentAlert {
  id       String   @id @default(cuid())
  vendorId String   @map("vendor_id")
  daysLeft Int      @map("days_left") // 90, 60, 30
  sentAt   DateTime @default(now()) @map("sent_at")
  vendor   Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([vendorId, daysLeft])
  @@map("vendor_sent_alerts")
}

// ตั้งค่า alert ของแต่ละ user (กี่วันล่วงหน้า + weekly summary)
model VendorAlertSetting {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  alertDays     Int[]    @default([90, 60, 30]) @map("alert_days")
  weeklySummary Boolean  @default(true) @map("weekly_summary")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@map("vendor_alert_settings")
}

// เก็บ refresh token เพื่อรองรับ revoke session (logout ทุกอุปกรณ์)
model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique               // SHA-256 hash of actual token
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}